@rendermode InteractiveServer
<div class="bingo-square" @onclick="ToggleTick">
    <div>
        @SquareText
    </div>
    <svg class="centered @(ticked ? "" : "hidden")" viewBox="0 0 100 100">
        <circle style="fill: @MarkerColor" cy="50" cx="50" r="50" fill-opacity="0.6" />
    </svg>
</div>

@code {
    [Parameter] public string SquareText { get; set; }
    [Parameter] public string MarkerColor { get; set; }
    bool ticked = false;

    void ToggleTick()
    {
        ticked = !ticked;
        Console.WriteLine("Clicked!!");
        StateHasChanged();
    }

}
